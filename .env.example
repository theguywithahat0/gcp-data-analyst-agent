# Required Environment Variables
GOOGLE_CLOUD_PROJECT=your-project-id
BQ_PROJECT_ID=your-project-id
BQ_DATASET_ID=your-dataset-id
AGENT_RESOURCE_NAME=your-deployed-agent-resource-name

# Model Configuration (using Gemini 2.0 Flash by default)
ROOT_AGENT_MODEL=gemini-2.0-flash-001
BIGQUERY_AGENT_MODEL=gemini-2.0-flash-001
ANALYTICS_AGENT_MODEL=gemini-2.0-flash-001
BQML_AGENT_MODEL=gemini-2.0-flash-001

# RAG Configuration (auto-created during deployment)
BUSINESS_RAG_CORPUS=
BQML_RAG_CORPUS_NAME=

# Optional Features
ENABLE_BQML=true
NL2SQL_METHOD=BASELINE

# Google Cloud Configuration
GOOGLE_CLOUD_LOCATION=us-central1

# Code Interpreter Configuration (optional)
CODE_INTERPRETER_EXTENSION_NAME= 